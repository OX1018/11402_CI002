#include <iostream>
#include <vector>
#include <algorithm>
#include <cctype>
#include <string>
using namespace std;

int main() {
    string s;
    bool first = true;

    while (getline(cin, s)) {
        if (!first) cout << "\n";
        first = false;

        int f[130] = {0};

        for (char c : s)
            f[(int)c]++;

        vector<pair<int,int>> v;

        for (int i = 0; i < 130; i++)
            if (f[i])
                v.push_back({f[i], -i});

        sort(v.begin(), v.end());

        for (auto &p : v)
            cout << -p.second << " " << p.first << "\n";
    }
}